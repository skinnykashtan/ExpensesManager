<Window x:Class="ExpensesManager.View.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExpensesManager"
        xmlns:userControls="clr-namespace:ExpensesManager.View.UserControls"
        mc:Ignorable="d"
        Title="Expense Manager" Height="720" Width="1280">
    <Grid Background="#EAF2F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="86"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1280*"/>
        </Grid.ColumnDefinitions>
        
        <Border Background="#76ACD9"/>
        <TextBlock Text="ExpensesManager" FontSize="56" Margin="70,0,0,0"
                   Foreground="#FFFFFF" FontWeight="Black" VerticalAlignment="Center"/>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Center"
                        Margin="10">
                <Button Height="30"
                        Width="140"
                        Margin="0,0,10,0"
                        Command="{Binding ShowTransactionsChartCommand}"
                        Content="Show Chart"/>

                <Button Height="30"
                        Width="140"
                        Command="{Binding ShowTransactionsCommand}"
                        Content="Show Transactions"/>
            </StackPanel>
            
            <!-- VIEW -->
            <Grid Grid.Column="0" Margin="45">
                <Border Background="White" CornerRadius="20" Padding="20">
                    <ContentControl Content="{Binding CurrentView}" />
                </Border>
            </Grid>

            <!-- SIDE PANEL -->
            <userControls:SidePanel 
                DataContext="{Binding SidePanelViewModel}" 
                Grid.Column="1" 
                Margin="20,45,45,45"/>
        </Grid>
    </Grid>
</Window>
