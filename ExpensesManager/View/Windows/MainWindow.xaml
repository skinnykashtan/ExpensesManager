<Window x:Class="ExpensesManager.View.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExpensesManager"
        xmlns:userControls="clr-namespace:ExpensesManager.View.UserControls"
        mc:Ignorable="d"
        Title="Expense Manager" Height="720" Width="1280">
    <Grid Background="#EAF2F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="86"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1280*"/>
        </Grid.ColumnDefinitions>
        
        <Border Background="#76ACD9"/>
        <TextBlock Text="Expense Manager" FontSize="56" Margin="70,0,0,0"
                   Foreground="#FFFFFF" FontWeight="Black" VerticalAlignment="Center"/>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            
            <Grid Grid.Column="0"/>
            
            <userControls:SidePanel Grid.Column="1" Margin="45"/>
        </Grid>
    </Grid>
</Window>
