<UserControl x:Class="ExpensesManager.View.UserControls.SidePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ExpensesManager.View.UserControls"
             xmlns:customControls="clr-namespace:ExpensesManager.CustomControls"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="230">
    <UserControl.Resources>
        <customControls:BalanceToColorConverter x:Key="BalanceColorConverter"/>
    </UserControl.Resources>
    <Grid>
        <Border
                    CornerRadius="12"
                    Background="#FFFFFF"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="3" Opacity="0.3"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="100"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Total Income" FontSize="18" Margin="10,30,0,0"
                               FontWeight="DemiBold"/>
                    <TextBlock Grid.Row="1" Text="{Binding TotalIncome}" Margin="10,5" Foreground="#16A34A"
                               FontSize="15" FontWeight="DemiBold"/>
                    
                    <TextBlock Grid.Row="2" Text="Total Expenses" FontSize="18" Margin="10,15,0,0"
                               FontWeight="DemiBold"/>
                    <TextBlock Grid.Row="3" Text="{Binding TotalExpenses}" Margin="10,5" Foreground="#E61818"
                               FontSize="15" FontWeight="DemiBold"/>
                    
                    <Border Grid.Row="4" Margin="30,10,30,0" Height="3" Background="#D6E2EC"
                            />
                    
                    <TextBlock Grid.Row="5" Text="Total Balance" FontSize="26" FontWeight="DemiBold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    <TextBlock Grid.Row="6" HorizontalAlignment="Center" FontSize="22"
                               FontWeight="DemiBold" Text="{Binding TotalBalance}"
                               Foreground="{Binding TotalBalance, Converter={StaticResource BalanceColorConverter}}"/>
                    
                    <TextBlock Grid.Row="8" Text="Top 3 Categories" FontSize="20" FontWeight="DemiBold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    
                    <Border Grid.Row="9" Margin="30,10,30,0" Height="3" Background="#D6E2EC"
                    />
                    
                    <TextBlock Grid.Row="10" Text="1. Food" FontSize="18"
                               FontWeight="DemiBold" Margin="35,5,0,0"/>
                    <TextBlock Grid.Row="11" Text="2. Transport" FontSize="18"
                               FontWeight="DemiBold" Margin="35,5,0,0"/>
                    <TextBlock Grid.Row="12" Text="3. Health" FontSize="18"
                               FontWeight="DemiBold" Margin="35,5,0,0"/>
                    
                    <Button Grid.Row="13" Name="btnAddTransaction" Content="+ Add Transaction"
                            Margin="0,15,0,0"
                            Cursor="Hand"
                            Height="30"
                            Width="200"
                            Foreground="#FFFFFF"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Click="BtnAddTransaction_OnClick">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="#76ACD9"
                                        CornerRadius="10">
                
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                
                                </Border>

                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border"
                                                Property="Background"
                                                Value="#3A5F7D"/>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border"
                                                Property="Background"
                                                Value="#4A6F8F"/>
                                    </Trigger>

                                </ControlTemplate.Triggers>

                            </ControlTemplate>
                        </Button.Template>

                    </Button>
                </Grid>
            </Border>
    </Grid>
</UserControl>
